{
  "manifest_version": 3,
  "name": "Meeting Transcriber",
  "version": "1.0.0",
  "description": "Real-time meeting transcription with speaker diarization for Google Meet and Zoom",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "Meeting Transcriber"
  },

  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*",
        "https://*.zoom.us/*",
        "https://teams.microsoft.com/*"
      ],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "tabCapture",
    "activeTab",
    "storage",
    "tabs",
    "scripting",
    "offscreen"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}